<?xml version="1.0" encoding="utf-8"?>
<!-- Neutral button background used in Components dialogs. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#283E57" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#212E3F" />
            <stroke
                android:width="1dp"
                android:color="@color/settings_outline" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
