<?xml version="1.0" encoding="utf-8"?>
<!-- Background shape for the Components item overflow menu. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/settings_popup_surface" />
    <stroke
        android:width="1dp"
        android:color="@color/settings_popup_surface_edge" />
    <corners android:radius="18dp" />
    <padding
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp" />
</shape>